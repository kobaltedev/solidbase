{
  "name": "@kobalte/solidbase",
  "version": "0.0.0-dev",
  "description": "Fully featured, fully customisable static site generation for SolidStart",
  "type": "module",
  "sideEffects": true,
  "scripts": {
    "dev": "pnpm -F @kobalte/solidbase-dev dev",
    "dev:docs": "pnpm -F @kobalte/solidbase-docs dev",
    "check": "biome check",
    "build": "tsc -b --force && node scripts/build.js",
    "build:docs": "pnpm -F @kobalte/solidbase-docs build",
    "format": "biome check --write #&& prettier . --write",
    "test": "vitest run",
    "typecheck": "tsc -b",
    "publish:next": "pnpm i && pnpm build && pnpm publish --tag next",
    "publish:release": "pnpm i && pnpm build && pnpm publish",
    "release": "pnpm tsx scripts/release.ts"
  },
  "keywords": [
    "solid",
    "solidjs",
    "solidstart",
    "documentation"
  ],
  "author": "jer3m01 <jer3m01@jer3m01.com>",
  "contributors": [
    "Brendan Allan <brendonovich@outlook.com>",
    "dev-rb <43100342+dev-rb@users.noreply.github.com>"
  ],
  "license": "MIT",
  "repository": {
    "url": "https://github.com/kobaltedev/solidbase"
  },
  "exports": {
    "./client": {
      "solid": "./src/client/index.tsx",
      "import": "./src/client/index.tsx",
      "types": "./src/client/index.tsx"
    },
    "./server": {
      "solid": "./src/server.tsx",
      "import": "./src/server.tsx",
      "types": "./src/server.tsx"
    },
    "./default-theme": {
      "solid": "./src/default-theme/index.ts",
      "import": "./src/default-theme/index.ts",
      "types": "./src/default-theme/index.ts"
    },
    "./default-theme/*": {
      "solid": "./src/default-theme/*",
      "import": "./src/default-theme/*",
      "types": "./src/default-theme/*"
    },
    "./mdx": {
      "solid": "./src/mdx.ts",
      "import": "./src/mdx.ts",
      "types": "./src/mdx.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      "./client": {
        "solid": "./dist/client/index.jsx",
        "import": "./dist/client/index.jsx",
        "types": "./dist/client/index.d.ts"
      },
      "./config": {
        "solid": "./dist/config/index.js",
        "import": "./dist/config/index.js",
        "types": "./dist/config/index.d.ts"
      },
      "./server": {
        "solid": "./dist/server.jsx",
        "import": "./dist/server.jsx",
        "types": "./dist/server.d.ts"
      },
      "./default-theme": {
        "solid": "./dist/default-theme/index.js",
        "import": "./dist/default-theme/index.js",
        "types": "./dist/default-theme/index.d.ts"
      },
      "./default-theme/*": {
        "solid": "./dist/default-theme/*",
        "import": "./dist/default-theme/*",
        "types": "./dist/default-theme/*"
      },
      "./mdx": {
        "solid": "./dist/mdx.js",
        "import": "./dist/mdx.js",
        "types": "./dist/mdx.d.ts"
      }
    }
  },
  "files": [
    "/src",
    "/dist"
  ],
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@octokit/core": "^6.1.6",
    "@solidjs/start": "https://pkg.pr.new/solidjs/solid-start/@solidjs/start@2080",
    "@types/cross-spawn": "^6.0.6",
    "@types/mdast": "^4.0.4",
    "@types/resolve": "^1.20.6",
    "@types/unist": "^3.0.3",
    "cross-env": "^7.0.3",
    "esbuild": "^0.25.12",
    "jsdom": "^29.0.0",
    "resolve": "^1.22.11",
    "solid-js": "^1.9.11",
    "tsx": "^4.21.0",
    "vfile": "^6.0.3",
    "vite": "^8.0.1",
    "vite-plugin-inspect": "^11.3.3",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "@solidjs/start": "^2.0.0",
    "solid-js": "^1.9.1",
    "vite": "^8.0.0"
  },
  "packageManager": "pnpm@10.6.2+sha512.47870716bea1572b53df34ad8647b42962bc790ce2bf4562ba0f643237d7302a3d6a8ecef9e4bdfc01d23af1969aa90485d4cebb0b9638fa5ef1daef656f6c1b",
  "dependencies": {
    "@alloc/quick-lru": "^5.2.0",
    "@bprogress/core": "^1.3.4",
    "@docsearch/css": "^3.9.0",
    "@expressive-code/core": "^0.41.7",
    "@expressive-code/plugin-collapsible-sections": "^0.41.7",
    "@expressive-code/plugin-frames": "^0.41.7",
    "@expressive-code/plugin-line-numbers": "^0.41.7",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/lexend": "^5.2.11",
    "@kobalte/core": "^0.13.11",
    "@mdx-js/mdx": "^3.1.1",
    "@solid-primitives/clipboard": "^1.6.4",
    "@solid-primitives/context": "^0.2.3",
    "@solid-primitives/event-listener": "^2.4.5",
    "@solid-primitives/keyboard": "^1.3.5",
    "@solid-primitives/media": "^2.3.5",
    "@solid-primitives/platform": "^0.1.2",
    "@solid-primitives/scroll": "^2.1.5",
    "@solid-primitives/storage": "^4.3.4",
    "@solidjs/meta": "^0.29.4",
    "@solidjs/router": "^0.15.4",
    "cross-spawn": "^7.0.6",
    "diff": "^8.0.3",
    "esast-util-from-js": "^2.0.1",
    "estree-util-value-to-estree": "^3.5.0",
    "expressive-code": "^0.41.7",
    "expressive-code-twoslash": "^0.4.0",
    "gray-matter": "^4.0.3",
    "hastscript": "^9.0.1",
    "magic-string": "^0.30.21",
    "mdast-util-find-and-replace": "^3.0.2",
    "mdast-util-mdx-jsx": "^3.2.0",
    "mdast-util-to-string": "^4.0.0",
    "mdast-util-toc": "^7.1.0",
    "parse-numeric-range": "^1.3.0",
    "prettier": "4.0.0-alpha.13",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-expressive-code": "^0.41.7",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "remark": "^15.0.1",
    "remark-directive": "^3.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "rollup": "^4.59.0",
    "source-map": "^0.7.6",
    "toml": "^3.0.0",
    "typescript": "^5.9.3",
    "unified": "^11.0.5",
    "unist-builder": "^4.0.0",
    "unist-util-mdx-define": "^1.1.2",
    "unist-util-visit": "^5.1.0",
    "unplugin-auto-import": "^19.3.0",
    "unplugin-icons": "^22.5.0",
    "yaml": "^2.8.2"
  },
  "engines": {
    "node": ">=22"
  }
}
